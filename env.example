# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database
MONGODB_URI=mongodb://localhost:27017/flappy-nft

# Sessions
SESSION_SECRET=your-super-secret-session-key-change-this

# Twitter OAuth
TWITTER_CONSUMER_KEY=your_twitter_api_key
TWITTER_CONSUMER_SECRET=your_twitter_api_secret

# JWT
JWT_SECRET=your-jwt-secret-key-change-this

# Solana
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_PROGRAM_ID=your_program_id_here

# CORS
CORS_ORIGIN=http://localhost:3000,https://yourdomainname.com
